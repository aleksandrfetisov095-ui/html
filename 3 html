    <section class="contact container my-5">
        <h2 class="section-title">Write to us</h2>
        <div class="form-box">
            <form action="#">
                <div class="row g-3">
                    <div class="form-group col-md-6">
                        <label for="name" class="form-label">Name</label>
                        <input type="text" id="name" class="form-control" placeholder="Your Name" required>
                    </div>
                    <div class="form-group col-md-6">
                        <label for="phone" class="form-label">Phone</label>
                        <input type="tel" id="phone" class="form-control" placeholder="+1 (___) ___-__-__" required>
                    </div>
                </div>

                <div class="form-group mt-3">
                    <label for="email" class="form-label">Email</label>
                    <input type="email" id="email" class="form-control" placeholder="example@mail.com" required>
                </div>

                <div class="form-group mt-3">
                    <label class="form-label">Contact via:</label>
                    <div class="radio-group d-flex gap-4 mt-2">
                        <label><input type="radio" name="contact_method" value="email" checked> Email</label>
                        <label><input type="radio" name="contact_method" value="phone"> Phone</label>
                        <label><input type="radio" name="contact_method" value="telegram"> Telegram</label>
                    </div>
                </div>

                <div class="form-group mt-3">
                    <label for="topic" class="form-label">Topic</label>
                    <select id="topic" class="form-select">
                        <option value="story">Send your story</option>
                        <option value="join">Join a trip</option>
                        <option value="movie">Participate in filming</option>
                    </select>
                </div>

                <div class="form-group mt-3">
                    <label for="message" class="form-label">Message</label>
                    <textarea id="message" rows="5" class="form-control" placeholder="Type your message here..."></textarea>
                </div>

                <div class="form-check mt-3">
                    <input type="checkbox" id="robot" class="form-check-input" required>
                    <label for="robot" class="form-check-label">I am not a robot</label>
                </div>

                <button type="submit" class="btn-submit mt-4">SEND</button>
            </form>
        </div>
    </section>

