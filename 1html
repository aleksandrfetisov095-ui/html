    <section class="contact container">
        <h2 class="section-title">Write to us</h2>
        <div class="form-box">
            <form action="#">
                <div class="form-row">
                    <div class="form-group">
                        <label for="name">Name</label>
                        <input type="text" id="name" placeholder="Your Name" required>
                    </div>
                    <div class="form-group">
                        <label for="phone">Phone</label>
                        <input type="tel" id="phone" placeholder="+1 (___) ___-__-__" required>
                    </div>
                </div>

                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" placeholder="example@mail.com" required>
                </div>

                <div class="form-group">
                    <label>Contact via:</label>
                    <div class="radio-group">
                        <label class="radio-label">
                            <input type="radio" name="contact_method" value="email" checked> Email
                        </label>
                        <label class="radio-label">
                            <input type="radio" name="contact_method" value="phone"> Phone
                        </label>
                        <label class="radio-label">
                            <input type="radio" name="contact_method" value="telegram"> Telegram
                        </label>
                    </div>
                </div>

                <div class="form-group">
                    <label for="topic">Topic</label>
                    <select id="topic">
                        <option value="story">Send your story</option>
                        <option value="join">Join a trip</option>
                        <option value="movie">Participate in filming</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="message">Message</label>
                    <textarea id="message" rows="5" placeholder="Type your message here..."></textarea>
                </div>

                <div class="checkbox-group">
                    <input type="checkbox" id="robot" required>
                    <label for="robot" style="margin:0; text-transform:none; letter-spacing:0;">I am not a robot</label>
                </div>

                <button type="submit" class="btn-submit">SEND</button>
            </form>
        </div>
    </section>

